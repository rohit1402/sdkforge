{
    "name": "sdkforge",
    "version": "0.1.0",
    "description": "Generate production-ready TypeScript SDKs from OpenAPI specifications",
    "type": "module",
    "bin": {
        "sdkforge": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "node build.mjs",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.{ts,mjs}\" \"*.{json,md,mjs}\"",
        "format:check": "prettier --check \"src/**/*.{ts,mjs}\" \"*.{json,md,mjs}\""
    },
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "@apidevtools/swagger-parser": "^10.1.0",
        "@modelcontextprotocol/sdk": "^0.6.0",
        "commander": "^12.1.0",
        "handlebars": "^4.7.8",
        "kleur": "^4.1.5",
        "openapi-types": "^12.1.3"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^20.14.0",
        "esbuild": "^0.23.0",
        "jest": "^29.7.0",
        "prettier": "^3.3.0",
        "ts-jest": "^29.1.0",
        "tsx": "^4.16.0",
        "typescript": "^5.5.0"
    }
}
